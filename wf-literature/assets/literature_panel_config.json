{
  "panel_name": "Literature Quality Panel",
  "version": "1.0.0",
  "purpose": "Post-collection quality review for workflow literature data",
  "experts": [
    {
      "id": "literature_specialist",
      "role": "Literature Specialist",
      "persona": "Academic database expert with 15+ years experience in bibliometric analysis. Specializes in PMID/DOI/PMCID mapping accuracy, metadata consistency across databases, and journal-topic fitness assessment.",
      "focus_areas": [
        "Metadata accuracy (title, authors, year, journal)",
        "ID mapping consistency (PMID ↔ DOI ↔ PMCID)",
        "Journal-topic fitness",
        "Duplicate detection",
        "Abstract completeness"
      ],
      "strictness": "high",
      "review_template": {
        "metadata_accuracy": "0-1 score",
        "id_consistency": "pass/fail",
        "journal_fitness": "0-1 score",
        "notes": "free text"
      }
    },
    {
      "id": "domain_expert",
      "role": "Domain Expert",
      "persona": "Biofoundry workflow specialist with deep knowledge of molecular biology, synthetic biology, and laboratory automation. Evaluates whether paper content is relevant to the target workflow domain and whether experimental protocols are suitable for case extraction.",
      "focus_areas": [
        "Domain relevance to target workflow",
        "Protocol suitability for case extraction",
        "Equipment/reagent specificity",
        "Experimental detail level",
        "Technique coverage"
      ],
      "strictness": "medium",
      "review_template": {
        "domain_relevance": "0-1 score",
        "protocol_suitability": "0-1 score",
        "equipment_specificity": "0-1 score",
        "notes": "free text"
      }
    },
    {
      "id": "critical_reviewer",
      "role": "Critical Reviewer",
      "persona": "Senior academic editor with 10+ years in scientific publishing. Detects extraction bias, over/under-collection, evidence level issues, and overall collection quality problems. Acts as the final quality arbiter.",
      "focus_areas": [
        "Collection bias (geographic, temporal, methodological)",
        "Evidence level assessment",
        "Gap detection (missing key papers)",
        "Over-extraction detection",
        "Overall quality verdict"
      ],
      "strictness": "high",
      "review_template": {
        "collection_bias": "none/low/medium/high",
        "evidence_level": "0-1 score",
        "gap_assessment": "free text",
        "overall_verdict": "accept/flag_recheck/reject",
        "notes": "free text"
      }
    }
  ],
  "consensus": {
    "threshold": 0.67,
    "tie_break": "flag_recheck",
    "verdicts": ["accept", "flag_recheck", "reject"],
    "reject_requires": "unanimous or 2/3 with critical_reviewer agreeing"
  },
  "mode_switch": {
    "description": "Switch from Full Panel to Quick Panel after confidence builds",
    "quick_after_runs": 5,
    "min_confidence": 0.8,
    "revert_on_severe_flag": true,
    "quick_panel_experts": ["critical_reviewer"]
  },
  "activation_conditions": {
    "mode": "ALWAYS",
    "description": "Panel review is MANDATORY for every workflow composition run"
  }
}
