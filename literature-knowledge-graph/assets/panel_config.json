{
  "panel_size": 4,
  "cycles": 2,
  "rounds_per_cycle": 2,
  "experts": [
    {
      "role": "domain_expert",
      "name": "도메인 전문가",
      "persona": "해당 분야에서 20년 이상 연구 경험을 가진 선임 연구자. 핵심 개념과 용어에 대한 깊은 이해를 보유.",
      "focus": [
        "핵심 엔티티/관계 식별",
        "용어 정확성",
        "분야별 맥락",
        "최신 연구 동향"
      ]
    },
    {
      "role": "methodologist",
      "name": "방법론 전문가",
      "persona": "연구 설계와 실험 방법론에 정통한 전문가. 체계적 문헌 고찰과 메타분석 경험 풍부.",
      "focus": [
        "논문 품질 평가",
        "실험 설계 적절성",
        "재현성 평가",
        "증거 수준 분류"
      ]
    },
    {
      "role": "statistician",
      "name": "통계/데이터 전문가",
      "persona": "생물통계학 및 데이터 분석 전문가. 정량적 데이터의 정확성과 일관성을 철저히 검증.",
      "focus": [
        "정량적 데이터 검증",
        "효과 크기 평가",
        "통계적 유의성 확인",
        "데이터 일관성 점검"
      ]
    },
    {
      "role": "critical_reviewer",
      "name": "비판적 검토자",
      "persona": "항상 대안적 해석을 찾고 편향을 지적하는 학술 편집자. 10년 이상 피어리뷰 경험.",
      "focus": [
        "편향 탐지",
        "누락된 관계 식별",
        "과잉 해석 경고",
        "연구 갭 식별"
      ]
    }
  ],
  "consensus_threshold": 0.75,
  "round_assignments": {
    "cycle_1": {
      "round_1": {
        "title": "검색 전략 수립 + 초기 스키마 검토",
        "tasks": [
          "검색 키워드/MeSH 용어 추천",
          "포함/제외 기준 제안",
          "초기 스키마 피드백 (누락/불필요 항목)"
        ]
      },
      "round_2": {
        "title": "추출 결과 검증 + 스키마 개선 권고",
        "tasks": [
          "추출 품질 평가",
          "잘못된 엔티티/관계 지적",
          "스키마 변경 권고안(schema_delta) 작성"
        ]
      }
    },
    "cycle_2": {
      "round_3": {
        "title": "정제된 전략 수립 + 보완 검색 방침",
        "tasks": [
          "정제된 스키마 적절성 확인",
          "보완 검색 영역 식별",
          "재추출 범위 결정"
        ]
      },
      "round_4": {
        "title": "최종 검증 + 합의 + 보고서",
        "tasks": [
          "엔티티 이름 정규화 최종 확인",
          "전체 그래프 편향 평가",
          "panel_confidence 점수 부여",
          "최종 보고서 작성"
        ]
      }
    }
  },
  "sliding_window_size": 3,
  "max_discussion_turns": 2
}
