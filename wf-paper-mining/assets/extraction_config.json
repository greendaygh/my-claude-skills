{
  "search_settings": {
    "primary_api": "pubmed",
    "fallback_api": "openalex",
    "default_select_n": 10,
    "pubmed": {
      "esearch_url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
      "efetch_url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/efetch.fcgi",
      "max_results": 300,
      "min_date": "2015",
      "sort": "relevance"
    },
    "openalex": {
      "base_url": "https://api.openalex.org/works",
      "max_results": 100,
      "sort": "relevance_score:desc",
      "polite_email": "wf-paper-mining@biofoundry.org"
    }
  },
  "execution": {
    "session_budget": 8,
    "rate_limit_delay_sec": 0.35,
    "max_retries": 2
  }
}
